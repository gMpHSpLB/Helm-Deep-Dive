# ---------------------------------------------------------------------------------------
#
# 	Exercise 3 — Understand the HPA + Replicas Conflict at Code Level
#	Task: Explain exactly what happens in the cluster if you set both 
#		  autoscaling.enabled: true AND replicas: 5 in the same values 
#		  file, with and without the conditional in the deployment template.
#	Answer:
#	Without the conditional ({{- if not .Values.autoscaling.enabled }}), the Deployment 
# 	would have spec.replicas: 5. The HPA also targets the same Deployment.
# 
# 	What happens:
# 		1.	HPA is created. It starts managing the Deployment replica count.
# 		2.	HPA scales to, say, 3 replicas based on low CPU.
# 		3.	The Deployment controller sees spec.replicas: 5 in its desired state 
#			(stored in etcd) and reconciles back to 5.
# 		4.	HPA sees 5 replicas, determines that's too many, scales back to 3.
# 		5.	Deployment controller reconciles to 5 again.
# 		6.	This loop continues indefinitely — the controllers fight each other.
#	
# 	With the conditional: when autoscaling.enabled: true, the replicas field is 
# 	completely absent from the rendered Deployment. The HPA is the sole authority 
# 	on replica count. The Deployment controller's desired state has no replica field 
# 	to fight over. The HPA wins cleanly.
#
# -----------------------------------------------------------------------------------------
.PHONY : k8s-verify-hpa-autoscaling-and-replica-relation-with-conditional
k8s-verify-hpa-autoscaling-and-replica-relation-with-conditional: ## verify-hpa-autoscaling-and-replica-relation-with-conditional
	@echo "With HPA disabled — replicas field present"
	helm template $(K8S_MYAPP_RELEASE_DEV) $(K8S_APP_HELM_CHART_DIR) \
	-f $(K8S_APP_DEV_VALUES_FILE) \
	--namespace $(K8S_APP_NAMESPACE_DEV) | grep "replicas:"

	@echo "With HPA enabled — replicas field should be absent"
	@echo "No output — field is correctly absent"
	helm template $(K8S_MYAPP_RELEASE_DEV) $(K8S_APP_HELM_CHART_DIR) \
	-f $(K8S_APP_DEV_VALUES_FILE) \
	--set autoscaling.enabled=true \
	--namespace $(K8S_APP_NAMESPACE_DEV) | grep "replicas:" || true

# --------------------------------------------------------------------------------------
#	Exercise 4 — Find What Changed Between Two Revisions
#	Task: You have a FAILED upgrade in history. Find exactly which 
#		  field changed between revision 1 and revision 2 without looking at Git.
#
# ---------------------------------------------------------------------------------------
.PHONY: k8s-get-diff-between-two-helm-revisions
k8s-get-diff-between-two-helm-revisions: ## Find What Changed Between Two Helm Revisions
	@echo "This is your primary post-incident investigation \
	tool when you need to know what changed between the last-good \
	and failed deployment without access to the CI logs."

	@echo "Get manifests from each revision"
	helm get manifest $(K8S_MYAPP_RELEASE_DEV) --revision 2 -n $(K8S_APP_NAMESPACE_DEV) > /tmp/rev1.yaml
	helm get manifest $(K8S_MYAPP_RELEASE_DEV) --revision 3 -n $(K8S_APP_NAMESPACE_DEV) > /tmp/rev2.yaml

	@echo "Get Diff of manifest files of both versions: "
	diff /tmp/rev1.yaml /tmp/rev2.yaml

	@echo "Or use coloured Diff: "
	diff --color /tmp/rev1.yaml /tmp/rev2.yaml

	@echo "Also compare the values that produced each revision"
	helm get values $(K8S_MYAPP_RELEASE_DEV) --revision 2 -n $(K8S_APP_NAMESPACE_DEV) > /tmp/vals1.yaml
	helm get values $(K8S_MYAPP_RELEASE_DEV) --revision 3 -n $(K8S_APP_NAMESPACE_DEV) > /tmp/vals2.yaml
	@echo "Get Diff of values of both versions: "
	diff --color /tmp/vals1.yaml /tmp/vals2.yaml





