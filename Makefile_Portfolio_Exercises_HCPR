# -----------------------------------------------------------------------------------
#   Exercise 1 — Debug a Silent Values Merge Failure
#
#   Task: Write a helm template command that proves the map-replacement trap from 
#   Exercise 4 is happening. Then write the correct fix.
#
# -----------------------------------------------------------------------------------
.PHONY: k8s-map-replacement-trap-not-merge
k8s-map-replacement-trap-not-merge: ## Proves map replacement, not merge for nested map
	@echo "Create a partial override that only sets one key in a nested map"
	@printf '%s\n' \
		'config:' \
		'  APP_LOG_LEVEL: "debug"' \
		> /tmp/prove-merge-bug.yaml
	@echo "Render and grep for config keys"
	@echo "Note: You will see ONLY APP_LOG_LEVEL — all other config keys are gone"
	@echo "This proves map replacement, not merge. This is the map replacement trap."
	helm template $(K8S_MYAPP_RELEASE_DEV) $(K8S_APP_HELM_CHART_DIR) \
		-f /tmp/prove-merge-bug.yaml \
		--namespace $(K8S_APP_NAMESPACE_DEV) | grep -A 20 "kind: ConfigMap"

.PHONY : k8s-how-to-avoid-map-replacement-trap
k8s-how-to-avoid-map-replacement-trap: ## how-to-avoid-map-replacement-trap
	@echo "THE FIX: always merge at the key level with --set for individual overrides"
	helm template $(K8S_MYAPP_RELEASE_DEV) $(K8S_APP_HELM_CHART_DIR) \
	-f $(K8S_APP_DEV_VALUES_FILE) \
	--set config.APP_LOG_LEVEL=debug \
	--namespace $(K8S_APP_NAMESPACE_DEV) | grep -A 20 "kind: ConfigMap"

