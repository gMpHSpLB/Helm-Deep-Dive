# ------------------------------------------------------------------------------------------------------
# Exercise 1 — Label Selector Query
#
# Task: List only pods that have app=myapp AND environment=dev labels.
# Why this matters in production: 
#    - When you have 50 pods across a namespace, label selectors are how you target the exact set you need. 
#    - Services use them to route traffic. Monitoring uses them to discover scrape targets.
#
# ------------------------------------------------------------------------------------------------------
.PHONY : k8s_label_query_selector
k8s_label_query_selector: ## List only pods that have app=myapp AND environment=dev labels.
	echo "List only pods that have app=myapp AND environment=dev labels"
	kubectl get pods -n myapp-dev -l "app=myapp,environment=dev"


# ------------------------------------------------------------------------------------------------------
# Exercise 2 — Verify Environment Variables Are Injected
#
# 	Task: Confirm that APP_ENV from ConfigMap and DB_PASSWORD 
#         from Secret are actually available inside the running container.
#
#	Expected output:
# 		APP_ENV=dev
# 		DB_PASSWORD=myapp-dev-db-password
# 		POD_NAME=myapp-7d8b9c4f5-x2kp9
# 		NODE_NAME=k8s-learning
#
# Hint(use exec and --env) ->  kubectl exec $$RUNNING_POD -n myapp-dev -- env
# ------------------------------------------------------------------------------------------------------
.PHONY : k8s_verify_env_variables_injected
k8s_verify_env_variables_injected: ## Confirm that APP_ENV from ConfigMap and DB_PASSWORD rom Secret are actually available inside the running container.
	echo "Get the name of a running pod"
	@RUNNING_POD=$$(kubectl get pods -n myapp-dev -l app=myapp -o jsonpath='{.items[0].metadata.name}'); \
	echo "Check environment variables inside the container $$RUNNING_POD "; \
	kubectl exec $$RUNNING_POD -n myapp-dev -- env | grep -E "APP_ENV|DB_PASSWORD|POD_NAME|NODE_NAME"

# ------------------------------------------------------------------------------------------------------
# Exercise 3 — ConfigMap Volume Mount Verification
#
# 	Task: Verify that app.ini from the ConfigMap is mounted as a file inside the container.
#
#	Expected output:
# 		[server]
# 		host = 0.0.0.0
# 		port = 8000
# 		workers = 2
#
# 		[logging]
# 		level = info
# 		format = json
# 		...
#
# ------------------------------------------------------------------------------------------------------
.PHONY : k8s_verify_configmap_valume_mounted
k8s_verify_configmap_valume_mounted: ## Verify that app.ini from the ConfigMap is mounted as a file inside the container.
	echo "Get the name of a running pod"
	@RUNNING_POD=$$(kubectl get pods -n myapp-dev -l app=myapp -o jsonpath='{.items[0].metadata.name}'); \
	echo "List files in the mounted directory"; \
	kubectl exec $$RUNNING_POD -n myapp-dev -n myapp-dev -- ls -la /etc/myapp/"



