Command Examples (Current Syntax)
bash
# ── SCAFFOLD ─────────────────────────────────────────────────────────
helm create myapp
# Creates charts/myapp/ with deployment, service, ingress, HPA, SA templates

# ── VALIDATE ─────────────────────────────────────────────────────────
helm lint ./charts/myapp -f charts/myapp/values-prod.yaml --strict
# Strict mode treats warnings as errors — use in CI

# ── RENDER WITHOUT DEPLOYING ─────────────────────────────────────────
helm template myapp-prod ./charts/myapp \
  -f charts/myapp/values-prod.yaml \
  --namespace myapp-prod \
  --kube-version 1.30 \
  --api-versions policy/v1/PodDisruptionBudget \
  --debug

# --kube-version: validates capability() calls against the target k8s version
# --api-versions: injects available API groups for capability checks

# ── IDEMPOTENT DEPLOY ────────────────────────────────────────────────
helm upgrade --install myapp-prod ./charts/myapp \
  -f charts/myapp/values-prod.yaml \
  --set image.tag="${GITHUB_SHA}" \
  --namespace myapp-prod \
  --create-namespace \
  --atomic \
  --cleanup-on-fail \
  --timeout 10m \
  --wait \
  --history-max 10

# --atomic: auto-rollback on failure (no stuck FAILED releases)
# --cleanup-on-fail: delete new resources created during a failed upgrade
# --history-max: keep only the last N revisions (prevents Secret accumulation)
# --wait: block until all resources are healthy

# ── PRE-UPGRADE DIFF ─────────────────────────────────────────────────
helm diff upgrade myapp-prod ./charts/myapp \
  -f charts/myapp/values-prod.yaml \
  --set image.tag="${GITHUB_SHA}" \
  --namespace myapp-prod \
  --suppress-secrets \
  --output dyff

# --suppress-secrets: redacts Secret data in diff output (security)
# --output dyff: human-friendly diff format (requires dyff binary)

# ── AUDIT ────────────────────────────────────────────────────────────
helm history myapp-prod -n myapp-prod --max 20 --output table

helm get manifest myapp-prod -n myapp-prod --revision 14 > revision-14.yaml
helm get manifest myapp-prod -n myapp-prod --revision 13 > revision-13.yaml
diff revision-13.yaml revision-14.yaml

# ── ROLLBACK ─────────────────────────────────────────────────────────
helm rollback myapp-prod 13 \
  -n myapp-prod \
  --wait \
  --timeout 5m
# Rollback creates revision 15 (new revision, not time-reversal)
# Previous revision 14 remains in history for audit purposes

# ── REGISTRY OPERATIONS ──────────────────────────────────────────────
# Add OCI registry (Helm 3.8+ — now stable, not experimental)
helm registry login registry.example.com \
  --username $REGISTRY_USER \
  --password $REGISTRY_PASSWORD

# Push chart to OCI registry
helm package ./charts/myapp --version 1.4.2
helm push myapp-1.4.2.tgz oci://registry.example.com/charts

# Pull from OCI registry
helm pull oci://registry.example.com/charts/myapp --version 1.4.2

# ── SHOW CHART INFO ──────────────────────────────────────────────────
helm show chart oci://registry.example.com/charts/myapp --version 1.4.2
helm show values oci://registry.example.com/charts/myapp --version 1.4.2

# ── DEPENDENCY MANAGEMENT ────────────────────────────────────────────
# Chart.yaml declares dependencies:
# dependencies:
#   - name: postgresql
#     version: "15.x.x"
#     repository: "oci://registry-1.docker.io/bitnamicharts"
#     condition: postgresql.enabled

helm dependency update ./charts/myapp
# Downloads dependencies to charts/myapp/charts/
# Creates Chart.lock with exact versions

helm dependency build ./charts/myapp
# Downloads exactly what Chart.lock specifies (reproducible)

# ── ENVIRONMENT INSPECTION ───────────────────────────────────────────
helm env
# Shows HELM_DATA_HOME, HELM_CACHE_HOME, HELM_CONFIG_HOME, etc.
# Useful when debugging plugin or repository issues

# ── TEST ─────────────────────────────────────────────────────────────
helm test myapp-prod -n myapp-prod \
  --timeout 5m \
  --logs
# Runs all pods with annotation: helm.sh/hook: test
# Returns exit code 0 if all tests pass (use in CI)

# ── PLUGIN MANAGEMENT ────────────────────────────────────────────────
helm plugin install https://github.com/databus23/helm-diff
helm plugin install https://github.com/helm-unittest/helm-unittest
helm plugin install https://github.com/jkroepke/helm-secrets
helm plugin list
