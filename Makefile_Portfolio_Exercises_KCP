#         from Secret are actually available inside the running container.
#
#	Expected output:
# 		APP_ENV=dev
# 		DB_PASSWORD=myapp-dev-db-password
# 		POD_NAME=myapp-7d8b9c4f5-x2kp9
# 		NODE_NAME=k8s-learning
#
# Hint(use exec and --env) ->  kubectl exec $$RUNNING_POD -n myapp-dev -- env
# ------------------------------------------------------------------------------------------------------
.PHONY : k8s-verify-env-variables-injected
k8s-verify-env-variables-injected: ## Confirm that APP_ENV from ConfigMap and DB_PASSWORD rom Secret are actually available inside the running container.
	@echo "Get the name of a running pod"
	@RUNNING_POD=$$(kubectl get pods -n $(K8S_APP_NAMESPACE_DEV) -l app=$(APP_NAME) -o jsonpath='{.items[0].metadata.name}'); \
	echo "Check environment variables inside the container $$RUNNING_POD "; \
	kubectl exec $$RUNNING_POD -n $(K8S_APP_NAMESPACE_DEV) -- env | grep -E "APP_ENV|DB_PASSWORD|POD_NAME|NODE_NAME"

