#			postgresql://myapp:myapp-dev-db-password@postgres:5432/myapp_dev
#		
#		Note: In a real production audit: You would RBAC-restrict who can get secrets. 
#			  You would also run your cluster with encryption at rest for etcd so the 
#			  base64 values in etcd are encrypted by a KMS key.
#  Hint (secret, -o jsonpath, base64 --decode)
# --------------------------------------------------------------------------------------------------------
.PHONY : k8s-decode-secret
k8s-decode-secret: # Decode the DATABASE_URL secret and display the plain text value.
	@echo "Get the Database url from secret and base64 decode it"
	kubectl get secret $(K8S_APP_SECRETS) -n $(K8S_APP_NAMESPACE_DEV) \
	-o jsonpath='{.data.DATABASE_URL}' | base64 --decode

# --------------------------------------------------------------------------------------------------------
#	Exercise 6 — Patch a Deployment Without Editing the File
#
#		Task: Update the APP_LOG_LEVEL in the ConfigMap to 
#			  debug and observe the change available in the 
#			  running container.
#
#		Lesson: 
#			1. Environment variables from ConfigMaps are injected at pod start time. 
#			   Changing the ConfigMap does NOT automatically update running pods. 
#			2.  Volume-mounted ConfigMaps update automatically (with a ~1 minute delay). 
#				This is a source of confusion in production — operators change a ConfigMap, 
#			    don't see the app change, and wonder why. 
#				The fix: always do a rollout restart after a ConfigMap change, or use the 
#                        checksum annotation pattern.
#	Hint (patch configmap, --type, get configmap, exec  --env, rollout restart, rollout status  )
# --------------------------------------------------------------------------------------------------------
.PHONY : k8s-patch-deployment-by-edit-configmap
k8s-patch-deployment-by-edit-configmap: ## Update the APP_LOG_LEVEL in the ConfigMap to debug and observe the change available in the running container.
	@echo "Update the ConfigMap"
	kubectl patch configmap $(K8S_APP_CONFIGMAPS) -n $(K8S_APP_NAMESPACE_DEV) \
		--type merge \
		-p '{"data":{"APP_LOG_LEVEL":"debug"}}'

	@echo "Verify the ConfigMap changed"
	kubectl get configmap $(K8S_APP_CONFIGMAPS) -n $(K8S_APP_NAMESPACE_DEV) -o jsonpath='{.data.APP_LOG_LEVEL}'
	# Output: debug

	@echo "The running pods still have the OLD value — ConfigMap env var changes require a pod restart to take effect."
	@RUNNING_POD=$$(kubectl get pods -n $(K8S_APP_NAMESPACE_DEV) -l app=myapp -o jsonpath='{.items[0].metadata.name}'); \
	kubectl exec $$RUNNING_POD -n $(K8S_APP_NAMESPACE_DEV) -- env | grep APP_LOG_LEVEL
	# Output: info  (still the old value)

	@echo "Restart the deployment to pick up the new ConfigMap value"
	kubectl rollout restart deployment/myapp -n $(K8S_APP_NAMESPACE_DEV)

	@echo "Wait for rollout"
	kubectl rollout status deployment/myapp -n $(K8S_APP_NAMESPACE_DEV)

	@echo "Now check the new pod"
	@NEW_POD=$$(kubectl get pods -n $(K8S_APP_NAMESPACE_DEV) -l app=$(APP_NAME) -o jsonpath='{.items[0].metadata.name}'); \
	kubectl exec $$NEW_POD -n $(K8S_APP_NAMESPACE_DEV) -- env | grep APP_LOG_LEVEL
	# Output: debug

# --------------------------------------------------------------------------------------------------------
#	Exercise 7 — Write a Debugging Playbook Entry
#
#		Task: Document the systematic approach for diagnosing a pod 
#             that is Running but returning HTTP 500 errors.
#
 #	Hint (get endpoints,logs, get pods, get events --sort-by=.lastTimestamp, exec -it, exec env,  )
# --------------------------------------------------------------------------------------------------------
.PHONY : k8s-display-debug-steps-for-pod
k8s-display-debug-steps-for-pod:
	@echo "Symptom: Pod status is Running/Ready but application returns HTTP 500"

	@echo "Resolution path: \
		→ Application bug → fix code, rebuild image, roll out \
		→ Config error → fix ConfigMap/Secret, rollout restart \
		→ Dependency down → check upstream service, fix networking \
		→ Resource pressure → increase limits or scale replicas"

	@echo "Step 1 — Confirm the pod is actually serving traffic"
	@echo " → Verify pod IP appears in endpoints. If not, readiness probe is failing."
	kubectl get endpoints $(APP_NAME) -n $(K8S_APP_NAMESPACE_DEV)
  	
	@echo "Step 2 — Check recent logs"
	@echo "→ Look for exception tracebacks, database connection errors, missing config"	
	@RUNNING_POD=$$(kubectl get pods -n $(K8S_APP_NAMESPACE_DEV) -l app=myapp -o jsonpath='{.items[0].metadata.name}'); \
	kubectl logs $$RUNNING_POD -n $(K8S_APP_NAMESPACE_DEV) --tail=100

	@echo "Step 3 — Check events for recent anomalies"
	@echo "→ Look for Liveness probe warnings, container restarts"	
	kubectl get events -n $(K8S_APP_NAMESPACE_DEV) --sort-by=.lastTimestamp | tail -20

	@echo "Step 4 — Exec into the container and test locally"
	@echo "→ wget -qO- http://localhost:8000/problematic-endpoint"
	@echo "→ Check if the error reproduces from inside the container"	
	@RUNNING_POD=$$(kubectl get pods -n $(K8S_APP_NAMESPACE_DEV) -l app=myapp -o jsonpath='{.items[0].metadata.name}'); \
	# Uncomment below
	#kubectl exec -it $$RUNNING_POD -n $(K8S_APP_NAMESPACE_DEV) -- sh

	@echo "Step 5 — Check ConfigMap and Secret values"
	@echo "→ Verify all expected variables are present with correct values"
	@echo "→ Especially check DB connection strings, API keys"	
	@RUNNING_POD=$$(kubectl get pods -n $(K8S_APP_NAMESPACE_DEV) -l app=myapp -o jsonpath='{.items[0].metadata.name}'); \
	kubectl exec $$RUNNING_POD -n $(K8S_APP_NAMESPACE_DEV) -- env

	@echo "Step 6 — Check resource pressure"
	@echo "→ CPU throttling causes slow responses, not 500s"
	@echo "→ Memory near limit can cause erratic behavior before OOMKill"
	@RUNNING_POD1=$$(kubectl get pods -n $(K8S_APP_NAMESPACE_DEV) -l app=myapp -o jsonpath='{.items[0].metadata.name}'); \
	kubectl top pod $$RUNNING_POD1 -n $(K8S_APP_NAMESPACE_DEV)

	@echo "Step 7 — Check upstream dependencies"
	@echo "→ NetworkPolicy may be blocking upstream connections"
	@echo "→ DNS resolution may be failing"
	@RUNNING_POD2=$$(kubectl get pods -n $(K8S_APP_NAMESPACE_DEV) -l app=myapp -o jsonpath='{.items[0].metadata.name}'); \
	kubectl exec $$RUNNING_POD2 -n $(K8S_APP_NAMESPACE_DEV) -- wget -qO- http://database-service:5432
