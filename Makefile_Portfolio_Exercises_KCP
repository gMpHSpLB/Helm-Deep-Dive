# --------------------------------------------------------------------------------------------------------
#	Exercise 4 — Scale the Deployment
#
#		Task: 1. Scale myapp to 4 replicas and verify all are Running and Ready.
#			  2. Then scale back to 2
#   In production: You never use kubectl scale directly — you update the replicas 
#				   field in your Git manifest and let ArgoCD apply it. This exercise 
#                  is to understand the mechanics.
#   Hint (scale deployment, --replicas=4)
# --------------------------------------------------------------------------------------------------------
.PHONY : k8s-scale-up-replicas
k8s-scale-up-replicas: ## Scale myapp to 4 replicas. Check all are running
	@echo "Scale the Deployment, Scale $(APP_NAME) to 4 replicas"
	kubectl scale deployment $(APP_NAME) --replicas=4 -n $(K8S_APP_NAMESPACE_DEV)

	@echo "Watch scaling up"
	kubectl get pods -n $(K8S_APP_NAMESPACE_DEV) -l app=$(APP_NAME) -w

.PHONY : k8s-verify-scale-up-deployment
k8s-verify-scale-up-deployment: ## Verify all are Ready.
	@echo "Verify Scale of the Deployment"
	@echo "Expected: READY 4/4"
	kubectl get deployment $(APP_NAME) -n $(K8S_APP_NAMESPACE_DEV)

.PHONY : k8s-scale-down-replicas
k8s-scale-down-replicas: ## Scale down myapp to 2 replicas and verify all are Running and Ready.
	@echo "Then scale back to 2:"
	kubectl scale deployment $(APP_NAME) --replicas=2 -n $(K8S_APP_NAMESPACE_DEV)

	@echo "Observe graceful termination"
	kubectl get pods -n $(K8S_APP_NAMESPACE_DEV) -l app=$(APP_NAME) -w

